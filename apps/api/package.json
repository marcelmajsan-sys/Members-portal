{
  "name": "@ecommerce-hr/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsc",
    "bundle": "esbuild src/lambda.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/lambda.mjs --external:@prisma/client --external:prisma --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\"",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@codegenie/serverless-express": "^4.17.1",
    "@ecommerce-hr/ai": "workspace:*",
    "@ecommerce-hr/db": "workspace:*",
    "@ecommerce-hr/email": "workspace:*",
    "@ecommerce-hr/shared": "workspace:*",
    "@prisma/client": "^6.5.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "bcryptjs": "^2.4.3",
    "bwip-js": "^4.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto-randomuuid": "^1.0.0",
    "express": "^5.0.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "imapflow": "^1.0.171",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.7.1",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.18.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/supertest": "^6.0.2",
    "esbuild": "^0.27.3",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
