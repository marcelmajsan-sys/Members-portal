{
  "installCommand": "cd ../.. && pnpm install && pnpm --filter @ecommerce-hr/db generate",
  "buildCommand": "node build-vercel.mjs",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ],
  "crons": [
    { "path": "/api/cron/fetch-inbound", "schedule": "0 * * * *" }
  ]
}
