{
  "name": "ecommerce-hr-os",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp"
    ]
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:admin": "turbo dev --filter=@ecommerce-hr/api --filter=@ecommerce-hr/os",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:migrate": "pnpm --filter @ecommerce-hr/db migrate:dev",
    "db:seed": "pnpm --filter @ecommerce-hr/db seed",
    "db:studio": "pnpm --filter @ecommerce-hr/db studio",
    "docker:up": "docker compose -f infrastructure/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f infrastructure/docker/docker-compose.yml down"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.15",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "turbo": "^2.8.16",
    "typescript-eslint": "^8.57.0"
  }
}
