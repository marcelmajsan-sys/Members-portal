# ─────────────────────────────────────────────────────────────
#  eCommerce HR OS — primjer .env (Supabase + Vercel + Resend)
#  Kopiraj ovo u ".env" i popuni svoje vrijednosti.
# ─────────────────────────────────────────────────────────────

# === BAZA (Supabase) ===
# Supabase dashboard → Project Settings → Database → Connection string.
# Koristi "Session pooler" (port 5432) za prisma db push i lokalni rad.
# Primjer: postgresql://postgres.<ref>:<lozinka>@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
DATABASE_URL=

# === AUTH (JWT) — već generirano, ne mijenjaj ===
JWT_SECRET=
JWT_REFRESH_SECRET=

# === AI (Anthropic Claude) — opcionalno, samo za "AI sažetak člana" ===
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# === EMAIL (Resend) — opcionalno; bez ovoga se emailovi ispisuju u konzolu ===
# https://resend.com → API Keys
RESEND_API_KEY=
EMAIL_FROM=noreply@tvoja-domena.hr

# === URL-ovi ===
# Lokalno ostavi ovako. Na produkciji postaviš na Vercel URL-ove.
NEXT_PUBLIC_API_URL=http://localhost:3001
OS_APP_URL=http://localhost:3003
API_BASE_URL=http://localhost:3001

# === Worker (Redis) — opcionalno, NE treba za osnovni rad ===
REDIS_URL=

# === App ===
NODE_ENV=development
API_PORT=3001
